<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Agent Timeline — {{ mode }}</title>
<script src="https://d3js.org/d3.v7.min.js"></script>
<style>
  body { font-family: -apple-system, BlinkMacSystemFont, sans-serif; margin: 20px; color: #222; }
  .tooltip {
    position: absolute; background: #222; color: #fff; padding: 6px 10px;
    border-radius: 4px; font-size: 12px; pointer-events: none; opacity: 0;
    transition: opacity 0.15s; max-width: 360px; line-height: 1.4; z-index: 10;
  }
</style>
</head>
<body>
<h1>Agent Timeline</h1>
<p><strong>{{ mode }}</strong> mode · {{ event_count }} events across {{ agents|length }} agents.
   Each agent is a bar spanning its active window; x-axis is event order (idle time compressed).</p>
<div id="timeline"></div>
<script>
window.TL = {
  agents: {{ agents|tojson }},
  events: {{ events|tojson }},
  spawnLinks: {{ spawn_links|tojson }},
  timeAnchors: {{ time_anchors|tojson }},
};
</script>
{% include "_timeline.js.j2" %}
</body>
</html>
